'use client'

import { useEffect, useState } from 'react'
import { useRouter } from 'next/navigation'
import { useSession } from 'next-auth/react'
import { motion } from 'framer-motion'
import { ArrowLeft, CheckCircle2 } from 'lucide-react'
import VZNAvatar from '@/components/ui/VZNAvatar'
import LoadingSpinner from '@/components/ui/LoadingSpinner'

interface DayPageProps {
  params: {
    week: string
    day: string
  }
}

export default function DayPage({ params }: DayPageProps) {
  const router = useRouter()
  const { data: session } = useSession()
  const week = parseInt(params.week)
  const day = parseInt(params.day)

  const [startup, setStartup] = useState<any>(null)
  const [mission, setMission] = useState<any>(null)
  const [dayTask, setDayTask] = useState<any>(null)
  const [loading, setLoading] = useState(true)
  const [step, setStep] = useState<'brief' | 'prep' | 'execution' | 'debrief' | 'complete'>('brief')
  
  const [prepAnswers, setPrepAnswers] = useState(['', '', ''])
  const [executionCount, setExecutionCount] = useState(0)
  const [debrief, setDebrief] = useState({
    whatHappened: '',
    theSignal: '',
    whatItMeans: '',
    whatChanges: '',
    tomorrowEdge: '',
  })
  const [debriefLoading, setDebriefLoading] = useState(false)

  const user = session?.user as any
  const userId = user?.id || user?.email

  useEffect(() => {
    if (!session || !userId) return

    const startupId = window.localStorage.getItem('visionix_active_startup_id')
    if (!startupId) {
      router.push('/dashboard')
      return
    }

    fetch(`/api/startups/${startupId}`)
      .then((res) => res.json())
      .then((data) => {
        setStartup(data)
        const warMission = data.warPlanJson?.find((m: any) => m.week === week)
        setMission(warMission)
        const task = warMission?.dailyTasks?.find((t: any) => t.day === day)
        setDayTask(task)
      })
      .catch((err) => console.error('Error fetching startup:', err))
      .finally(() => setLoading(false))
  }, [session, userId, week, day, router])

  const handleDebriefSubmit = async () => {
    setDebriefLoading(true)
    try {
      const response = await fetch('/api/ai/debrief-analysis', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          ...debrief,
          marketIntelligence: startup?.marketIntelligence,
        }),
      })
      const analysis = await response.json()

      await fetch(`/api/day/complete`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          id: startup.id,
          week,
          day,
          debrief,
          ...analysis,
        }),
      })

      setStep('complete')
    } catch (error) {
      console.error('Error submitting debrief:', error)
    } finally {
      setDebriefLoading(false)
    }
  }

  if (loading) {
    return (
      <main className="grid min-h-screen place-items-center bg-[var(--bg-primary)]">
        <LoadingSpinner label="Loading..." />
      </main>
    )
  }

  if (!startup || !mission || !dayTask) {
    return (
      <main className="grid min-h-screen place-items-center bg-[var(--bg-primary)]">
        <VZNAvatar size="lg" />
      </main>
    )
  }

  return (
    <main className="min-h-screen bg-[var(--bg-primary)] px-6 py-10 text-[var(--text-primary)]">
      <div className="sticky top-0 z-20 mb-8 -mx-6 px-6 py-4 border-b border-[var(--border)] bg-[var(--bg-secondary)]">
        <div className="mx-auto max-w-4xl flex items-center justify-between">
          <button onClick={() => router.back()}>
            <ArrowLeft size={24} />
          </button>
          <div className="text-center">
            <div className="text-sm text-[var(--amber)] font-mono">{mission?.missionCode}</div>
            <h1 className="text-2xl font-bold">{mission?.missionName}</h1>
          </div>
          <div className="text-right">
            <div className="text-2xl font-bold">🔥 {startup?.streakCount || 0}</div>
          </div>
        </div>
      </div>

      <div className="mx-auto max-w-4xl space-y-8">
        {step === 'brief' && dayTask && (
          <motion.div initial={{ opacity: 0, y: 24 }} animate={{ opacity: 1, y: 0 }}>
            <div className="rounded-2xl border p-6 bg-[var(--card-bg)] border-[var(--border)]">
              <h2 className="text-2xl font-bold mb-6">{dayTask.task}</h2>
              <button onClick={() => setStep('prep')} className="w-full rounded-lg bg-[var(--purple)] px-4 py-3 font-semibold text-white">
                Start task
              </button>
            </div>
          </motion.div>
        )}

        {step === 'prep' && (
          <motion.div initial={{ opacity: 0, y: 24 }} animate={{ opacity: 1, y: 0 }} className="space-y-4">
            <h3 className="text-lg font-bold">Prep</h3>
            {['Hypothesis?', 'Go wrong?', 'Success?'].map((q, i) => (
              <textarea key={i} value={prepAnswers[i]} onChange={(e) => { const ans = [...prepAnswers]; ans[i] = e.target.value; setPrepAnswers(ans); }} placeholder={q} className="w-full bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg px-4 py-3 text-white text-sm" rows={2} />
            ))}
            <button onClick={() => setStep('execution')} className="w-full rounded-lg bg-[var(--purple)] px-4 py-3 font-semibold text-white">
              Continue
            </button>
          </motion.div>
        )}

        {step === 'execution' && (
          <motion.div initial={{ opacity: 0, y: 24 }} animate={{ opacity: 1, y: 0 }}>
            <div className="rounded-2xl border p-6 bg-[var(--card-bg)]">
              <div className="text-6xl font-bold text-center mb-6" style={{ color: 'var(--purple)' }}>
                {executionCount}
              </div>
              <div className="flex gap-2 justify-center mb-6">
                <button onClick={() => setExecutionCount(Math.max(0, executionCount - 1))} className="px-6 py-3 rounded-lg border border-[var(--border)]">−</button>
                <button onClick={() => setExecutionCount(executionCount + 1)} className="px-6 py-3 rounded-lg border border-[var(--border)]">+</button>
              </div>
              <button onClick={() => setStep('debrief')} className="w-full rounded-lg bg-[var(--purple)] px-4 py-3 font-semibold text-white">
                Done
              </button>
            </div>
          </motion.div>
        )}

        {step === 'debrief' && (
          <motion.div initial={{ opacity: 0, y: 24 }} animate={{ opacity: 1, y: 0 }} className="space-y-4">
            <h3 className="text-lg font-bold">Debrief</h3>
            {[{ k: 'whatHappened', l: 'What happened?' }, { k: 'theSignal', l: 'Key signal?' }, { k: 'whatItMeans', l: 'Means?' }, { k: 'whatChanges', l: 'Changes?' }, { k: 'tomorrowEdge', l: 'Tomorrow?' }].map((f) => (
              <textarea key={f.k} value={(debrief as any)[f.k]} onChange={(e) => setDebrief({ ...debrief, [f.k]: e.target.value })} placeholder={f.l} className="w-full bg-[var(--bg-secondary)] border border-[var(--border)] rounded-lg px-4 py-3 text-white text-sm" rows={2} />
            ))}
            <button onClick={handleDebriefSubmit} disabled={debriefLoading} className="w-full rounded-lg bg-[var(--purple)] px-4 py-3 font-semibold text-white disabled:opacity-50">
              {debriefLoading ? 'Submitting...' : 'Submit'}
            </button>
          </motion.div>
        )}

        {step === 'complete' && (
          <motion.div initial={{ opacity: 0, y: 24 }} animate={{ opacity: 1, y: 0 }}>
            <div className="rounded-2xl border p-6 bg-[var(--card-bg)] border-[var(--teal)] text-center">
              <CheckCircle2 size={64} className="text-[var(--teal)] mx-auto mb-4" />
              <h2 className="text-3xl font-bold mb-2">Complete</h2>
              <button onClick={() => router.push(`/dashboard/warplan/${week}`)} className="mt-6 w-full rounded-lg bg-[var(--purple)] px-4 py-3 font-semibold text-white">
                Back
              </button>
            </div>
          </motion.div>
        )}
      </div>
    </main>
  )
}
