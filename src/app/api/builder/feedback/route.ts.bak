import { NextResponse } from 'next/server'
import { connectMongo } from '@/lib/mongodb'
import Artifact from '@/models/Artifact'
import AgentJob from '@/models/AgentJob'

export async function POST(req: Request) {
  try {
    await connectMongo()
    const { artifactId, feedback } = await req.json()

    if (!artifactId || !feedback) {
      return NextResponse.json({ error: 'artifactId and feedback are required' }, { status: 400 })
    }

    const artifact = await Artifact.findById(artifactId)
    if (!artifact) {
      return NextResponse.json({ error: 'Artifact not found' }, { status: 404 })
    }

    // Save human feedback to the artifact
    artifact.humanFeedback = feedback
    artifact.isApproved = false
    await artifact.save()

    // Re-queue the respective agent to revise the artifact based on feedback
    const agentRole = artifact.artifactType === 'prd' ? 'Product Manager' : 'Software Architect'
    
    const agentJob = await AgentJob.create({
      workspaceId: artifact.workspaceId,
      agentRole: agentRole,
      status: 'pending',
      startedAt: new Date(),
      logs: [{ message: `Re-triggered ${agentRole} with human feedback.`, level: 'info' }]
    })

    // Simulate async kick-off
    console.log(`[Builder] Re-triggered ${agentRole} for artifact: ${artifactId} with feedback`)

    return NextResponse.json({ success: true, jobId: agentJob._id })
  } catch (error: any) {
    console.error('Feedback submission error:', error)
    return NextResponse.json({ error: 'Failed to process feedback', details: error.message }, { status: 500 })
  }
}
