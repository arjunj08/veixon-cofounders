import { NextResponse } from 'next/server'
import { connectMongo } from '@/lib/mongodb'
import Workspace from '@/models/Workspace'
import AgentJob from '@/models/AgentJob'
import Artifact from '@/models/Artifact'

export async function GET(req: Request) {
  try {
    const { searchParams } = new URL(req.url)
    const startupId = searchParams.get('startupId')

    if (!startupId) {
      return NextResponse.json({ error: 'startupId is required' }, { status: 400 })
    }

    await connectMongo()

    const workspace = await Workspace.findOne({ startupId })
    if (!workspace) {
      return NextResponse.json({ status: 'not_started' })
    }

    const jobs = await AgentJob.find({ workspaceId: workspace._id }).sort({ createdAt: -1 })
    const artifacts = await Artifact.find({ workspaceId: workspace._id }).sort({ createdAt: -1 })

    return NextResponse.json({
      workspace: workspace.status,
      jobs,
      artifacts
    })
  } catch (error: any) {
    console.error('Status fetch error:', error)
    return NextResponse.json({ error: 'Failed to fetch status' }, { status: 500 })
  }
}
