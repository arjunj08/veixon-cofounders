import { NextResponse } from 'next/server'
import { connectMongo } from '@/lib/mongodb'
import Workspace from '@/models/Workspace'
import AgentJob from '@/models/AgentJob'

export async function POST(req: Request) {
  try {
    await connectMongo()
    const { startupId, phase } = await req.json()

    if (!startupId || !phase) {
      return NextResponse.json({ error: 'startupId and phase are required' }, { status: 400 })
    }

    // 1. Find or create a Workspace for this startup
    let workspace = await Workspace.findOne({ startupId })
    if (!workspace) {
      workspace = await Workspace.create({ startupId, status: 'planning' })
    }

    // 2. Create an AgentJob to track the orchestrator
    const agentJob = await AgentJob.create({
      workspaceId: workspace._id,
      agentRole: 'Orchestrator',
      status: 'pending',
      startedAt: new Date()
    })

    // TODO: Trigger actual background processing queue (e.g., Celery/Redis, or external Python service).
    // For now, we simulate an async kickoff by acknowledging receipt.
    // In Vercel, serverless functions timeout quickly, so do not block here.
    
    // Simulate background kick-off
    console.log(`[Builder] Kicked off agent pipeline phase: ${phase} for workspace: ${workspace._id}`)

    return NextResponse.json({ 
      success: true, 
      workspaceId: workspace._id, 
      jobId: agentJob._id,
      message: 'Agent orchestration job enqueued successfully'
    })
  } catch (error: any) {
    console.error('Agent orchestration error:', error)
    return NextResponse.json({ error: 'Failed to enqueue agent job', details: error.message }, { status: 500 })
  }
}
