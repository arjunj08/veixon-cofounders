import { Resend } from 'resend'
import { callClaudeJson } from '@/lib/anthropic'
import { connectMongo } from '@/lib/mongodb'
import Startup from '@/models/Startup'

export const runtime = 'nodejs'
export const maxDuration = 60

async function handler(req: Request) {
  try {
    const secret = req.headers.get('x-cron-secret')
    if (secret !== process.env.CRON_SECRET) return Response.json({ error: 'Unauthorized', fallback: true }, { status: 401 })

    let startups: any[] = []
    try {
      await connectMongo()
      const cutoff = new Date()
      cutoff.setDate(cutoff.getDate() - 14)
      startups = await Startup.find({ updatedAt: { $gte: cutoff } }).limit(100).lean()
    } catch {
      startups = []
    }

    const resend = process.env.RESEND_API_KEY ? new Resend(process.env.RESEND_API_KEY) : null
    let sent = 0

    for (const startup of startups) {
      const payload = {
        tasks: startup.warPlanJson?.[0]?.dailyTasks || [],
        oath: startup.oath || 'I commit.',
        startup: startup.ideaText,
      }
      let missile: any
      try {
        missile = await callClaudeJson({
          system:
            'Write Monday email as VZN. Direct, sharp, zero fluff. Reference specific tasks by name. Give exactly ONE task. End with the founder oath. Return ONLY valid JSON: { subject:string, body:string, singleTask:string }.',
          body: payload,
          maxTokens: 800,
        })
      } catch {
        missile = {
          subject: 'VZN Monday Missile',
          body: `You need one proof point this week. Oath: ${payload.oath}`,
          singleTask: 'Complete one customer conversation with a payment ask.',
        }
      }

      if (resend && startup.email) {
        await resend.emails.send({
          from: 'VZN <onboarding@resend.dev>',
          to: startup.email,
          subject: missile.subject,
          html: `
            <div style="background:rgb(13,13,15);color:rgb(245,245,245);padding:32px;font-family:Inter,Arial,sans-serif">
              <div style="color:rgb(83,74,183);font-weight:700;letter-spacing:.1em;margin-bottom:24px">VEIXON CO-FOUNDERS</div>
              <p style="line-height:1.6">${missile.body}</p>
              <div style="border:1px solid rgb(239,159,39);color:rgb(239,159,39);padding:16px;border-radius:12px;margin:24px 0">${missile.singleTask}</div>
              <a href="${process.env.NEXT_PUBLIC_APP_URL || process.env.NEXTAUTH_URL || ''}/dashboard" style="background:rgb(83,74,183);color:white;padding:12px 18px;border-radius:8px;text-decoration:none">Open War Plan</a>
            </div>
          `,
        })
        sent++
      }
    }

    return Response.json({ processed: startups.length, sent })
  } catch {
    return Response.json({ error: 'Cron unavailable', fallback: true }, { status: 500 })
  }
}

export { handler as GET, handler as POST }
