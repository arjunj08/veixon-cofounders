import { NextResponse } from 'next/server'
import { connectMongo } from '@/lib/mongodb'
import User from '@/models/User'
import Startup from '@/models/Startup'
import { sendPushNotification, sendEmail, buildEmailHtml } from '@/lib/notifications'

export const runtime = 'nodejs'
export const maxDuration = 60

export async function POST(req: Request) {
  if (req.headers.get('x-cron-secret') !== process.env.CRON_SECRET) {
    return NextResponse.json({ error: 'Unauthorized' }, { status: 401 })
  }

  try {
    await connectMongo()

    // Active users with notifications enabled in last 14 days
    const users = await User.find({
      notificationsEnabled: true,
      lastActiveDate: { $gte: new Date(Date.now() - 14 * 24 * 60 * 60 * 1000) },
    }).lean()

    let processed = 0

    for (const user of users) {
      try {
        const startup = await Startup.findOne({ userId: (user as any)._id?.toString() || (user as any).email }).lean()
        if (!startup) continue

        const dayNumber =
          Math.floor(
            (Date.now() - new Date((startup as any).createdAt).getTime()) /
              (1000 * 60 * 60 * 24)
          ) + 1

        const currentWeek = Math.ceil(dayNumber / 7)
        const currentDay = ((dayNumber - 1) % 7) + 1
        const warPlan = (startup as any).warPlanJson
        const todayTask =
          warPlan?.[currentWeek - 1]?.dailyTasks?.[currentDay - 1]?.task ||
          "Complete today's mission"
        const missionCode = warPlan?.[currentWeek - 1]?.missionCode || 'ACTIVE MISSION'

        const APP_URL =
          process.env.NEXT_PUBLIC_APP_URL ||
          process.env.NEXTAUTH_URL ||
          'https://visionixfounders.com'

        // Push notification
        if ((user as any).fcmToken) {
          await sendPushNotification((user as any).fcmToken, {
            title: `Day ${dayNumber} — ${missionCode}`,
            body: `Today: ${todayTask.substring(0, 80)}...`,
            url: `${APP_URL}/dashboard/warplan/${currentWeek}/${currentDay}`,
            tag: `morning-${dayNumber}`,
          })
        }

        // Email
        const html = buildEmailHtml({
          subject: `VZN Morning Brief — Day ${dayNumber}`,
          preheader: `${missionCode} is active. Here's your mission.`,
          headline: `Day ${dayNumber}. ${missionCode} is active.`,
          body: `Today's task: ${todayTask}. VZN is watching whether you complete it before midnight. Your current streak is ${(user as any).streakCount || 0} days.`,
          ctaText: "Open today's mission",
          ctaUrl: `${APP_URL}/dashboard/warplan/${currentWeek}/${currentDay}`,
          highlightLine: `Mission: ${todayTask}`,
        })

        if ((user as any).email) {
          await sendEmail({
            to: (user as any).email,
            subject: `VZN Morning Brief — Day ${dayNumber}`,
            html,
          })
        }

        processed++
      } catch (err) {
        console.error(`Morning briefing failed for ${(user as any).email}:`, err)
      }
    }

    return NextResponse.json({ success: true, processed })
  } catch (err) {
    console.error('Morning briefing cron error:', err)
    return NextResponse.json({ error: 'Cron failed' }, { status: 500 })
  }
}
