import { redirect } from 'next/navigation'
import { getServerSession } from 'next-auth'
import { authOptions } from '@/lib/auth'
import prisma from '@/lib/prisma'

export default async function RoutingPage() {
  const session = await getServerSession(authOptions)

  if (!session || !session.user) {
    redirect('/auth')
  }

  let hasStartup = false

  try {
    const startup = await prisma.startup.findFirst({ where: { userId: session.user.id } })
    if (startup) {
      hasStartup = true
    }
  } catch (error) {
    console.error('Database connection failed in routing. Defaulting to intake flow:', error)
    hasStartup = false
  }

  if (hasStartup) {
    // Returning user with an idea
    redirect('/dashboard')
  } else {
    // First time login / no idea submitted / DB offline
    redirect('/intake')
  }
}
